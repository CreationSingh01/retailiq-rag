# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Voyage AI (embeddings) ──────────────────────────────────────────────────
# Get from https://dash.voyageai.com — if omitted, ANTHROPIC_API_KEY is used as fallback
# VOYAGE_API_KEY=pa-...

# ── Supabase ───────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...   # replaces anon key (client-side)
SUPABASE_SECRET_KEY=sb_secret_...             # replaces service_role key (server-side)

# ── Direct Postgres connection (for psycopg2 / pgvector DDL) ───────────────
# Found in: Supabase dashboard → Project Settings → Database → Connection string
# Use the "URI" format (Session pooler on port 5432 or direct on 6543)
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# ── Optional ───────────────────────────────────────────────────────────────
# Override the API URL in the frontend (defaults to http://localhost:8000)
# RETAILIQ_API=https://your-deployed-backend.up.railway.app
